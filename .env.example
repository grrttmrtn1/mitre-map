# Copy this to .env and fill in values before running docker compose.

JWT_SECRET=replace-with-a-strong-random-secret

# Default admin user created on first run (remove after initial setup if desired)
ADMIN_EMAIL=admin@example.com
BOOTSTRAP_TOKEN=replace-with-a-long-random-one-time-secret
BOOTSTRAP_WINDOW_MS=1800000
ADMIN_PASSWORD=changeme

# Optional overrides (defaults shown)
# MITREMAP_PORT=8443
# CLIENT_URL=https://localhost:8443
# APP_URL=https://localhost:8443

# TLS certificates (PEM format).
# If omitted, a self-signed certificate is generated automatically.
# SSL_CERT_PATH=/app/certs/server.crt
# SSL_KEY_PATH=/app/certs/server.key
